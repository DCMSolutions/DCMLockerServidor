@page "/"
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<style>
    .online-status {
        display: flex;
        align-items: center;
    }

    .online-dot {
        width: 10px;
        height: 10px;
        background-color: green;
        border-radius: 50%;
        animation: pulse 1s infinite;
    }

    .status-text {
        margin-left: 10px;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.2);
        }

        100% {
            transform: scale(1);
        }
    }
</style>

